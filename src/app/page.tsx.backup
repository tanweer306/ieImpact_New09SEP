            <div className="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-primary-300 to-success-300 rounded-full hidden lg:block"></div>

            <div className="space-y-12 lg:space-y-24">
              {[
                {
                  step: "01",
                  title: "Submit Your Data Requirements",
                  description: "Upload your inspection sheets, property details, or any data that needs to be entered. Our secure portal accepts all file formats.",
                  icon: FileText,
                  side: "left"
                },
                {
                  step: "02", 
                  title: "Our Experts Process Your Information",
                  description: "Trained professionals with appraisal expertise carefully enter your data with rigorous quality control at every step.",
                  icon: Users,
                  side: "right"
                },
                {
                  step: "03",
                  title: "Receive Accurate, Formatted Reports",
                  description: "Get your completed reports back in your preferred format, ready for client delivery. Fast, accurate, and professional.",
                  icon: CheckCircle,
                  side: "left"
                }
              ].map((step, index) => (
                <motion.div
                  key={index}
                  initial={{ opacity: 0, x: step.side === 'left' ? -50 : 50 }}
                  whileInView={{ opacity: 1, x: 0 }}
                  transition={{ duration: 0.8, delay: index * 0.2 }}
                  viewport={{ once: true }}
                  className={`flex items-center gap-8 ${step.side === 'right' ? 'lg:flex-row-reverse' : ''}`}
                >
                  {/* Content */}
                  <div className="flex-1 lg:max-w-md">
                    <div className={`bg-white rounded-xl p-8 shadow-lg border border-gray-100 ${step.side === 'right' ? 'lg:text-right' : ''}`}>
                      <div className={`flex items-center gap-4 mb-4 ${step.side === 'right' ? 'lg:justify-end' : ''}`}>
                        <div className="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center">
                          <step.icon className="w-6 h-6 text-primary-600" />
                        </div>
                        <span className="text-3xl font-bold text-primary-600">{step.step}</span>
                      </div>
                      <h3 className="text-xl font-bold text-primary-900 mb-3">{step.title}</h3>
                      <p className="text-gray-600 leading-relaxed">{step.description}</p>
                    </div>
                  </div>

                  {/* Timeline Node (Desktop) */}
                  <div className="hidden lg:block relative">
                    <motion.div
                      animate={{ scale: [1, 1.2, 1] }}
                      transition={{ duration: 2, repeat: Infinity, ease: "easeInOut", delay: index * 0.5 }}
                      className="w-6 h-6 bg-primary-600 rounded-full border-4 border-white shadow-lg"
                    ></motion.div>
                  </div>

                  {/* Spacer */}
                  <div className="flex-1 lg:max-w-md hidden lg:block"></div>
                </motion.div>
              ))}
            </div>
          </div>
        </div>
      </section>

      {/* Contact/CTA Section */}
